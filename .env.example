# 复制本文件为 .env.local 后填写（不要提交 .env.local）。

# Kimi（Moonshot）API Key，用于 lib/llm 模型适配层
KIMI_API_KEY=

# 可选：开放平台文档为 https://api.moonshot.ai/v1；若你环境仅可用国内节点可改为 https://api.moonshot.cn/v1
# KIMI_BASE_URL=

# 可选：模型 ID，默认 moonshot-v1-8k；以控制台「模型列表」为准，例如 kimi-k2-0905-preview
# KIMI_MODEL=

# 你已部署的 EasyClaw 站点，例如：https://your-app.vercel.app
NEXT_PUBLIC_EASYCLAW_APP_URL=

# 可选：Skill 包单独落地页。留空则按钮与上一项相同。
NEXT_PUBLIC_SKILL_INSTALL_URL=

# 在 GitHub 创建仓库并 push 本工程后填写，例如：https://github.com/你的用户名/career-war-room
NEXT_PUBLIC_GITHUB_REPO_URL=
